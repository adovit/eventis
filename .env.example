# Supabase — create project at https://supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=        # frontend read-only
SUPABASE_SERVICE_ROLE_KEY=     # scraper write access — never expose to frontend

# Bright Data — scraping proxy (used by scripts/scraper only, not bundled into frontend)
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_ZONE=

# Stripe — needed from Iteration 3 onwards
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=    # Edge Function only — get from Stripe dashboard → Webhooks
SITE_URL=                 # e.g. https://eventis.lt — used by Edge Functions for redirect URLs

# Resend — email delivery (Iteration 3 onwards)
RESEND_API_KEY=           # Edge Function only — get from resend.com
